# Saved answers for repeatable / non-interactive setup runs.
# Copy to answers.env (git-ignored) and pass with: ./setup.sh --answers answers.env
# Any value left unset is prompted for. Secrets are only written back if you opt in.

# --- Panel / API ---------------------------------------------------------------
PANEL_URL=https://panel.example.com
# APP_API_KEY=   # application API key — leave blank to be prompted (not stored by default)
PELICAN_DIR=/opt/pelican

# --- Server basics -------------------------------------------------------------
SRV_NAME=StarMade Server
SRV_USER=1
SRV_MEMORY=6144
SRV_DISK=10240
SRV_CPU=0

# --- StarMade options (map to egg variables) -----------------------------------
# STARMADE_BRANCH=release      # release | dev | pre | archive
# STARMADE_VERSION=latest
# MAX_CLIENTS=32
